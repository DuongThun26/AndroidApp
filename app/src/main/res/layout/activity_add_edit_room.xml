<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <EditText
            android:id="@+id/edtRoomId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mã phòng (Ví dụ: P101)"
            android:inputType="text" />

        <EditText
            android:id="@+id/edtRoomName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tên phòng"
            android:inputType="text"
            android:layout_marginTop="8dp"/>

        <EditText
            android:id="@+id/edtPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Giá thuê (VND)"
            android:inputType="numberDecimal"
            android:layout_marginTop="8dp"/>

        <Switch
            android:id="@+id/switchStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tình trạng: Đã thuê?"
            android:textSize="16sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/edtTenantName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tên người thuê"
            android:inputType="textPersonName" />

        <EditText
            android:id="@+id/edtPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Số điện thoại"
            android:inputType="phone"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LƯU THÔNG TIN"
            android:layout_marginTop="24dp"/>

    </LinearLayout>
</ScrollView>